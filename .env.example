DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_server_id
PORT=3000

# Optional: security log channel (defaults to configured channel ID in config.js)
# SECURITY_LOG_CHANNEL_ID=1512796032944046090

# Optional: self-ping to stay awake on Render (auto-set as RENDER_EXTERNAL_URL on Render)
# SELF_PING_URL=https://madrazobot.onrender.com
# SELF_PING_INTERVAL_MS=180000
